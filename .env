# ===========================================
# Soofi Trainer - Environment Configuration
# ===========================================

# --- Secrets File ---
# Path to the secrets file (stored outside the repo, e.g. in home directory)
# Create this file with your API keys (see below)
ENV_SECRETS_FILE=~/.env.secrets

# --- Weaviate Configuration ---
WEAVIATE_VERSION=1.35.7
WEAVIATE_PORT=8070
WEAVIATE_COLLECTION=SoofiKnowledge

# --- Vector MCP Server Configuration ---
# Vector MCP has no external port — only reachable via Docker network (vector-mcp:8000)
EMBEDDING_MODEL=openai:text-embedding-3-large

# --- MCP Inspector Configuration ---
# UI on port 6274, Proxy on port 6277
MCPINSPECTOR_VERSION=0.18.0
MCPINSPECTOR_CLIENT_PORT=6274
MCPINSPECTOR_PROXY_PORT=6277
MCP_AUTH_TOKEN=dev-stack-token-12345

# --- MinIO Configuration ---
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
KNOWLEDGE_BASE_URL=http://localhost:9000/knowledge
MINIO_BUCKET=knowledge
MINIO_ACCESS_KEY=soofi
MINIO_SECRET_KEY=soofi-minio-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Open WebUI Configuration ---
OPENWEBUI_VERSION=v0.7.2
OPENWEBUI_PORT=3000

# --- N8N ---
# PostgreSQL
POSTGRES_VERSION=18-alpine

# n8n Configuration
N8N_VERSION=2.8.3
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EXTERNAL_PORT=5678
GENERIC_TIMEZONE=Europe/Berlin

# --- Training Backend Configuration ---
# Backend type: "local" (subprocess) or "docker" (Docker API)
TRAINING_BACKEND=docker
# Remote Docker API URL (e.g., ssh://user@gpu-server, tcp://gpu-server:2376)
# Leave unset to use the local Docker socket (/var/run/docker.sock)
# TRAINING_DOCKER_HOST=
# Docker image for training containers
TRAINING_IMAGE=soofi-trainer-dummy-training:latest
# GPU device ID ("all" for all GPUs, or specific ID like "0")
# TRAINING_GPU_DEVICE=all
# Webhook callback URL that training containers use to reach the gateway
TRAINING_GATEWAY_URL=http://training-gateway:8000/webhooks
# Docker network for training containers
TRAINING_CONTAINER_NETWORK=soofi-trainer_soofi-network
# Default simulation duration in seconds (for dummy training container)
TRAINING_DEFAULT_DURATION=120
TRAINING_GATEWAY_PORT=8099

# ===========================================
# Secrets File (~/.env.secrets)
# ===========================================
# Create a file at the path above with:
#
# OPENAI_API_KEY=sk-your-key-here
#
# This file is NOT stored in the repository.
