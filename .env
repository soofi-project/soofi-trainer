# ===========================================
# Soofi Trainer - Environment Configuration
# ===========================================

# --- Soofi Trainer Version (all self-built images) ---
SOOFI_TRAINER_VERSION=0.2.6

# --- Secrets File ---
# Path to the secrets file (stored outside the repo, e.g. in home directory)
# Create this file with your API keys (see below)
ENV_SECRETS_FILE=~/.env.secrets

# --- Portainer Configuration ---
PORTAINER_VERSION=2.39.0
PORTAINER_PORT=9090

# --- Landing Page Configuration ---
# Set the domain (e.g. 'soofi.mrk40.de') for the Let's Encrypt certificate via Cloudflare DNS-Challenge here (profile=domain)
LANDING_PAGE_HOSTNAME=localhost
LANDING_PAGE_PORT=443
LANDING_PAGE_WATCH_SLIDES=true

# --- AAS Configuration ---
BASYX_VERSION=2.0.0-milestone-08
AAS_WEBUI_V3_VERSION=v2-260122
AAS_WEBUI_PORT=8280
# feasible duplicate of LANDING_PAGE_HOSTNAME, but allows more flexible configuration (e.g. if AAS environment is on a different host/subdomain)
AAS_HOSTNAME=${LANDING_PAGE_HOSTNAME}
AAS_DISCOVERY_PORT=8290
AAS_REGISTRY_PORT=8287
SM_REGISTRY_PORT=8288
AAS_ENVIRONMENT_PORT=8289
MNESTIX_BROWSER_PORT=8281
MNESTIX_PROXY_PORT=8265
MNESTIX_BACKEND_API_KEY=dev-stack-mnestix-key
NEXTAUTH_SECRET=dev-stack-nextauth-secret
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRET_ENC_KEY=J+mMxwKo+aoFJ6uxMv6Acv54buuBir2EJ3z6LGFB+Vo=

# --- EDC Configuration ---
EDC_PROVIDER_PORT=8390
EDC_CONSUMER_PORT=8391
EDC_PORTAL_PROVIDER_PORT=8380
EDC_PORTAL_CONSUMER_PORT=8381
EDC_CONSUMER_MCP_PORT=8392

# --- Weaviate Configuration ---
WEAVIATE_VERSION=1.36.2
WEAVIATE_PORT=8070
WEAVIATE_COLLECTION=SoofiKnowledge

# --- Vector MCP Server Configuration ---
VECTOR_MCP_VERSION=0.1.0
# Vector MCP has no external port — only reachable via Docker network (vector-mcp:8000)
EMBEDDING_MODEL=openai:text-embedding-3-large
# Reranker mode: distance (score from vector distance) | vllm (Qwen3-Reranker via vLLM, H200 only)
RERANKER_MODE=distance

#EMBEDDING_MODEL=ollama:bge-m3
# Only needed when using an Ollama embedding model:
#OLLAMA_HOST=http://host.docker.internal:11434



# --- MCP Inspector Configuration ---
# UI on port 6274, Proxy on port 6277
MCPINSPECTOR_VERSION=0.18.0
MCPINSPECTOR_CLIENT_PORT=6274
MCPINSPECTOR_PROXY_PORT=6277
MCP_AUTH_TOKEN=dev-stack-token-12345

# --- MinIO Configuration ---
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
KNOWLEDGE_BASE_URL=/docs
MINIO_BUCKET=knowledge
MINIO_ACCESS_KEY=soofi
MINIO_SECRET_KEY=soofi-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- LLM Endpoint ---
# Empty = OpenAI (api.openai.com). For local/H200 usage set:
# Ollama:      OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# LM Studio:   OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# Triton H200: OPENAI_BASE_URL=http://triton-host:8000/v1
# NOTE: For Ollama/LM Studio/Triton: set OPENAI_API_KEY to any value (e.g. "ollama")
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# --- Knowledge Ingestion Configuration ---
KNOWLEDGE_INGESTION_VERSION=0.1.0

# --- Advisor Configuration ---
ADVISOR_MODEL=gpt-4o-mini

# --- Training Agent Configuration ---
TRAINING_AGENT_MODEL=gpt-4o-mini

# --- Dataset Agent Configuration ---
DATASET_AGENT_MODEL=gpt-4o-mini
DATASETAGENT_VERSION=0.1.0

# --- Huggingface Configuration ---
HUGGINGFACE_MCP_VERSION=0.1.0

# --- Interaction Agent Configuration ---
INTERACTION_MODEL=gpt-4o-mini
SESSION_LOG_ENABLED=true
SESSION_LOG_HOST_DIR=./session-logs
SESSION_LOG_TIMEOUT_S=300

# --- Trainer Agent Configuration ---

# --- Soofi UI Configuration ---
SOOFI_UI_PORT=3001

STT_PROVIDER=openai
STT_MODEL=whisper-1
STT_LANGUAGE=de
STT_PORT=8010
WHISPER_PROMPT_DE=Soofi, RAG, Retrieval-Augmented Generation, LoRA, QLoRA, PDF, SFT, DPO, Fine-Tuning, LLM, LangGraph, Weaviate, Embedding, Wissensdatenbank, Sprachmodell, Transformer, Tokenizer, Inferenz, Quantisierung, Trainingsjob, Trainingsauftrag
WHISPER_PROMPT_EN=Soofi, RAG, Retrieval-Augmented Generation, LoRA, QLoRA, PDF, SFT, DPO, Fine-Tuning, LLM, LangGraph, Weaviate, Embedding, Transformer, Tokenizer, Inference, Quantization, training job
# H200 local (via LiteLLM): STT_BASE_URL=http://10.2.10.33:4000/v1
# Cloud OpenAI (default):   leave unset (set via --vllm or --triton override)

# --- TTS Configuration ---
TTS_PROVIDER=openai
TTS_MODEL=tts-1
TTS_SPEED=1.2
# Phonetic replacements for German Piper voices (pipe-separated, aligned 1:1).
# Maps english loanwords to German phonetic spelling so Piper pronounces them correctly.
TTS_DE_PHONETIC_KEYS=Fine-Tuning     | fine-tuning   | Finetuning  | Embedding   | Embeddings  | embedding   | embeddings  | Training | training | Knowledge Base | Dataset    | Datasets   | dataset    | Pipeline | pipeline | Chunk    | Chunks   | chunk    | chunks   | Feature     | Batch  | batch  | Token  | Tokens | Agent     | Performance  | LoRA  | RAG | Retrieval-Augmented Generation               | Retrieval  | Low-Rank Adaptation
TTS_DE_PHONETIC_VALUES=Fein-Tjuning  | Fein-Tjuning  | Feintjuning | Emmbädding  | Emmbäddings | Emmbädding  | Emmbäddings | Trehning | Trehning | Nolädsch Beis  | Dätasett   | Dätasetts  | Dätasett   | Peiplein | Peiplein | Tschank  | Tschanks | Tschank  | Tschanks | Fiehttscher | Bätsch | Bätsch | Tohken | Tohkens| Ehdschent | Pörformänss  | Lohra | Räg | Retriewal Augmented Dschenereh-schen         | Retriewal  | Loh-Ränk Ädäptäischen
TTS_PORT=8011
# H200 local (via LiteLLM): TTS_BASE_URL=http://10.2.10.33:4000/v1
# Cloud OpenAI (default):   leave unset (set via --vllm or --triton override)
# H200 voices (Piper, CPU):
# Voice mapping: alloy = thorsten-high (DE männl.)
#                echo/fable = thorsten_emotional (DE männl.)
#                nova = kerstin (DE weibl.)
#                onyx/shimmer = lessac-high (EN)

# --- Voice UI Configuration ---
VITE_VOICE_CONTROLS_VISIBLE=true
# push-to-talk: hold to record, release to send | toggle: click once to start, once to stop (VAD stops after 1.5s silence)
VITE_VOICE_ACTIVATION=push-to-talk
# Key to activate the microphone (KeyboardEvent.code, e.g. Space, Enter)
VITE_VOICE_ACTIVATION_KEY=space
VITE_TTS_VOICE_DE=nova
VITE_TTS_VOICE_EN=shimmer

# --- Training Backend Configuration ---
# Backend type: "local" (subprocess) or "docker" (Docker API)
TRAINING_BACKEND=docker
# Remote Docker API URL (e.g., ssh://user@gpu-server, tcp://gpu-server:2376)
# Leave unset to use the local Docker socket (/var/run/docker.sock)
# TRAINING_DOCKER_HOST=
# Docker image for training containers
TRAINING_IMAGE_NAME=dfkisoofi/training-container
TRAINING_IMAGE_VERSION=0.0.1
# GPU device ID ("all" for all GPUs, or specific ID like "0"). Leave empty for no GPU (local dev/simulation).
TRAINING_GPU_DEVICE=
# Default simulation duration in seconds (for dummy training container)
TRAINING_DEFAULT_DURATION=120
TRAINING_GATEWAY_VERSION=0.1.0
TRAINING_GATEWAY_PORT=8099

# --- Monitoring (Grafana / Prometheus) ---
GRAFANA_VERSION=12.3
GRAFANA_PORT=3002
GRAFANA_ADMIN_PASSWORD=admin

PROMETHEUS_VERSION=v3.10.0

# ===========================================
# Secrets File (~/.env.secrets)
# ===========================================
# Create a file at the path above with:
#
# OPENAI_API_KEY=sk-your-key-here
#
# This file is NOT stored in the repository.
