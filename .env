# ===========================================
# Soofi Trainer - Environment Configuration
# ===========================================

# --- Secrets File ---
# Path to the secrets file (stored outside the repo, e.g. in home directory)
# Create this file with your API keys (see below)
ENV_SECRETS_FILE=~/.env.secrets

# --- Weaviate Configuration ---
WEAVIATE_PORT=8070
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=SoofiKnowledge

# --- Vector MCP Server Configuration ---
VECTOR_MCP_PORT=8113
EMBEDDING_MODEL=openai:text-embedding-3-large

# --- MCP Inspector Configuration ---
# MCP Inspector runs in host network mode, default port is 6274

# --- Open WebUI Configuration ---
OPENWEBUI_VERSION=v0.7.2
OPENWEBUI_PORT=3000

# ===========================================
# Secrets File (~/.env.secrets)
# ===========================================
# Create a file at the path above with:
#
# OPENAI_API_KEY=sk-your-key-here
#
# This file is NOT stored in the repository.
